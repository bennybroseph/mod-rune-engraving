########################################
# mod-rune-engraving configuration
########################################
#
#    RuneEngraving.Enable
#        Description: Master switch for the rune engraving engine. When disabled,
#                     the catalog is not loaded, the engraver NPC is inert, and no
#                     rune spells are applied on login. The module is a no-op.
#        Default:     1 - (Enabled)
#                     0 - (Disabled)
#

RuneEngraving.Enable = 1
